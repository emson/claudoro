{
  "name": "claudoro",
  "displayName": "Claudoro",
  "version": "0.1.5",
  "description": "Pomodoro timer for Claude Code — live countdown in the status line",
  "homepage": "https://github.com/emson/claudoro",
  "author": {
    "name": "Ben Emson"
  },
  "license": "MIT",
  "keywords": [
    "pomodoro",
    "timer",
    "focus",
    "status-line",
    "productivity"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pomo setup --quiet || true"
          }
        ]
      }
    ]
  }
}
